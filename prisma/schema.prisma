// bindr — Pokémon binder builder + physical fulfillment
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum Tier {
  FREE
  PAID
}

enum Visibility {
  PRIVATE
  UNLISTED
  PUBLIC
}

enum SlotStatus {
  EMPTY
  OWNED // collector already has this card
  WANTED // to be sourced during fulfillment
}

enum FulfillmentState {
  REQUESTED
  QUOTED
  PAID
  SOURCING
  PARTIALLY_SOURCED // some wanted cards could not be found
  SOURCED
  ASSEMBLING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

// ---------- Better Auth ----------
model User {
  id               String   @id
  name             String
  email            String   @unique
  emailVerified    Boolean  @default(false)
  image            String?
  role             Role     @default(USER)
  tier             Tier     @default(FREE)
  stripeCustomerId String?  @unique
  stripeSubscriptionId String?
  subscriptionStatus   String? // active | trialing | past_due | canceled …
  currentPeriodEnd     DateTime?
  preferredLocale  String   @default("en")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  sessions          Session[]
  accounts          Account[]
  binders           Binder[]
  fulfillmentOrders FulfillmentOrder[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

// ---------- Card data (synced from TCGdex — multi-language + pricing) ----------
model Card {
  id         String    @id // "${language}:${tcgdexId}", e.g. "en:sv03.5-006"
  tcgdexId   String // raw TCGdex id, e.g. "sv03.5-006"
  language   String    @default("en") // en | es | fr | de | it | pt | ja | ko …
  name       String // localized
  nameEn     String? // English name alias so non-EN cards are searchable in English
  dexId      Int? // primary national Pokédex number (for cross-language name mapping)
  number     String // collector number within set (TCGdex localId)
  setId      String
  setName    String
  setSeries  String?
  rarity     String?
  supertype  String? // Pokémon / Trainer / Energy
  subtypes   String[] // Basic, Stage 2, ex, V, Supporter, Item, Stadium, Pokémon Tool …
  types      String[] // energy types: Fire, Water, …
  artist     String?
  isFullArt  Boolean   @default(false) // heuristic (illustration/alt/secret art)
  marketEur  Decimal?  @db.Decimal(10, 2) // denormalized latest Cardmarket EUR, for sorting
  imageBase  String? // TCGdex asset base; append `/high.png`, `/low.png`
  releasedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  prices PriceSnapshot[]
  slots  BinderSlot[]

  @@unique([tcgdexId, language])
  @@index([name])
  @@index([nameEn])
  @@index([language])
  @@index([supertype])
  @@index([artist])
  @@index([marketEur])
  @@map("card")
}

model PriceSnapshot {
  id        String   @id @default(cuid())
  cardId    String
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  source    String // "cardmarket" | "tcgplayer"
  variant   String   @default("normal") // normal | holofoil | reverseHolofoil
  price     Decimal  @db.Decimal(10, 2)
  currency  String // "EUR" | "USD"
  fetchedAt DateTime @default(now())

  @@index([cardId, source, fetchedAt])
  @@map("price_snapshot")
}

// ---------- Binders ----------
model Binder {
  id          String     @id @default(cuid())
  ownerId     String
  owner       User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  title       String     @default("Untitled binder")
  description String?
  theme       String     @default("midnight") // backdrop/theme key
  visibility  Visibility @default(PRIVATE)
  pageCount   Int        @default(1)
  columns     Int        @default(3) // 3x3 = 9-pocket page
  rows        Int        @default(3)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  slots             BinderSlot[]
  fulfillmentOrders FulfillmentOrder[]

  @@index([ownerId])
  @@map("binder")
}

model BinderSlot {
  id        String     @id @default(cuid())
  binderId  String
  binder    Binder     @relation(fields: [binderId], references: [id], onDelete: Cascade)
  position    Int // flat index across all pages
  cardId      String?
  card        Card?      @relation(fields: [cardId], references: [id], onDelete: SetNull)
  status      SlotStatus @default(EMPTY)
  sleeve      String? // decorative sleeve insert (preset key), mutually exclusive with a card
  customImage String? // user-uploaded image URL (Vercel Blob), mutually exclusive with a card
  note        String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([binderId, position])
  @@index([binderId])
  @@map("binder_slot")
}

// ---------- Fulfillment ----------
model FulfillmentOrder {
  id                    String           @id @default(cuid())
  binderId              String
  binder                Binder           @relation(fields: [binderId], references: [id])
  userId                String
  user                  User             @relation(fields: [userId], references: [id])
  state                 FulfillmentState @default(REQUESTED)
  currency              String           @default("EUR")
  cardsTotal            Decimal?         @db.Decimal(10, 2) // sum of sourced-card prices at request time
  serviceFee            Decimal?         @db.Decimal(10, 2)
  shippingFee           Decimal?         @db.Decimal(10, 2)
  quotedTotal           Decimal?         @db.Decimal(10, 2) // cards + fee + shipping
  stripeSessionId       String?
  stripePaymentIntentId String?
  paidAt                DateTime?
  // Frozen shipping address (snapshot at request time)
  shipName    String?
  shipLine1   String?
  shipLine2   String?
  shipCity    String?
  shipPostal  String?
  shipCountry String?
  carrier      String?
  trackingCode String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  items FulfillmentItem[]

  @@index([userId])
  @@index([state])
  @@map("fulfillment_order")
}

// Processed Stripe webhook event ids — idempotency guard.
model StripeEvent {
  id        String   @id // Stripe event id
  type      String
  createdAt DateTime @default(now())

  @@map("stripe_event")
}

// One row per card to source in an order (snapshot — the binder can change later).
model FulfillmentItem {
  id        String           @id @default(cuid())
  orderId   String
  order     FulfillmentOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  cardId    String?
  name      String
  setName   String
  number    String
  imageBase    String?
  priceEur     Decimal?      @db.Decimal(10, 2) // quoted (daily estimate)
  sourcedPrice Decimal?      @db.Decimal(10, 2) // actual cost paid at sourcing
  sourced      Boolean       @default(false)
  createdAt    DateTime      @default(now())

  @@index([orderId])
  @@map("fulfillment_item")
}
